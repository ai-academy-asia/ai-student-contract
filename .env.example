# Аппын тохиргоо (.env болгож хуулаад утгуудаа тохируулна)

# PostgreSQL холболт (серверт суусан Postgres)
DATABASE_URL=postgresql://contract:contract123@localhost:5432/contract_db

# Гэрээний нийтийн линкийн домэйн (DB-д хадгалагдах contract_link, мөн
# AI Engineer сертификатын QR доторх баталгаажуулах URL-ийн үндэс).
PUBLIC_BASE_URL=https://ai-academy.asia

# ЗААВАЛ (production): AI Engineer сертификатын QR токеныг HMAC-SHA256-аар
# гарын үсэглэх нууц. Тохируулаагүй бол хэн ч хуурамч "баталгаажсан" QR үүсгэж
# чадна. Санамсаргүй урт утгаар солино (ж: `openssl rand -hex 32`).
CERT_SIGNING_SECRET=СОЛИХ-урт-санамсаргүй-нууц

# Заавал биш: PDF-д ашиглах крилл фонт (default нь OS-оос автоматаар олно)
# Linux дээр fonts-liberation суулгасан бол:
# PDF_FONT=/usr/share/fonts/truetype/liberation/LiberationSerif-Bold.ttf
